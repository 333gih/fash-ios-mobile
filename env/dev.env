# Dev — Auth & API
# Emulator: 10.0.2.2 = host machine. Physical device: use your PC's LAN IP (e.g. 192.168.1.100) — add to network_security_config.xml if needed.
# OTP is single-use: request OTP in the app, then verify in the app. Do NOT verify in Swagger first.
ENVIRONMENT_NAME=dev
# JWT và các endpoint auth (login, refresh, OTP, …) — ví dụ .../auth-service/en/api/v1/auth/login
AUTH_SERVICE_BASE_URL=https://api-auth.fashandcurious.com/
API_BASE_URL=https://api-core.fashandcurious.com/
# common-service (catalog GETs: addresses, brands, categories, aesthetic-tags, countries) — ANDROID_API_INTEGRATION.md
COMMON_SERVICE_BASE_URL=https://api-common.fashandcurious.com/
# Optional: same as server INTERNAL_SECRET → sent as X-Internal-Secret. Leave empty for normal user-JWT-only flows.
INTERNAL_SECRET=8b4d4f3b6c3d45c5e21c2e1a8f1f5b8a4c1d9e7a2f8c6d4b
# Optional: service JWT when no user is logged in (Authorization Bearer). User session overrides when present.
INTERNAL_SERVICE_BEARER_TOKEN=8b4d4f3b6c3d45c5e21c2e1a8f1f5b8a4c1d9e7a2f8c6d4b
# Core-service only: true => {base}/vi/api/... or {base}/en/api/... from app language; false => {base}/api/... (legacy).
CORE_API_USE_LANGUAGE_PREFIX=true
# true|false — prefix ngôn ngữ cho AUTH_SERVICE_BASE_URL (mặc định giống CORE_API_USE_LANGUAGE_PREFIX).
AUTH_API_USE_LANGUAGE_PREFIX=true
# When true, hide sizing-reference onboarding even if sizing_reference_completed is false (e.g. dev).
SKIP_SIZING_REFERENCE_COMPLETED=false
# Secured GET: setup/home flags (must match core-service — use setup-status, not legacy access-status, if that is what Swagger exposes).
CORE_USER_ACCESS_STATUS_PATH=api/v1/users/me/setup-status
AUTH_CLIENT_ID=fash-android-dev
# Must match an applications.id row (see migrations/init_schema.sql seed fash-mobile).
AUTH_APPLICATION_ID=web
AUTH_CLIENT_SECRET=

# POST relative to AUTH_SERVICE_BASE_URL
AUTH_OTP_REQUEST_PATH=api/v1/auth/otp/request
AUTH_OTP_VERIFY_PATH=api/v1/auth/otp/verify
AUTH_LOGIN_PATH=api/v1/auth/login
AUTH_LOGOUT_PATH=api/v1/auth/logout
AUTH_LOGOUT_ALL_PATH=api/v1/auth/logout-all
AUTH_FCM_REGISTER_PATH=api/v1/auth/fcm/register
AUTH_REFRESH_PATH=api/v1/auth/refresh
AUTH_CHANGE_PASSWORD_PATH=api/v1/auth/change-password
# GET/PATCH identity — same JWT as core; merged into profile in app.
AUTH_ME_PATH=api/v1/auth/me

# From Meta for Developers → your app → Settings → Basic
FACEBOOK_LOGIN_ENABLED=false
FACEBOOK_APP_ID=940995382097327
FACEBOOK_CLIENT_TOKEN=23dff93cd150b947ceb55afdcec6f4d6

# Google Sign-In — MUST be the OAuth 2.0 Client ID of type "Web application" (GCP → APIs & Services → Credentials).
# If you only downloaded a JSON whose root is "installed", that is a Desktop/other client: create a NEW
# "Web application" client in the SAME project and paste THAT client id here (it may differ from the installed id).
# Also create Android OAuth clients (same project): package com.pc.fash_android_mobile.dev + SHA-1 debug keystore;
# package com.pc.fash_android_mobile + SHA-1 release/upload for prod builds. fash-auth-service: set GOOGLE_OAUTH_CLIENT_IDS
# fash-auth-service .env.prod: GOOGLE_OAUTH_CLIENT_IDS must equal this Web client id (comma-separated if several).
GOOGLE_WEB_CLIENT_ID=598587496348-3m7us7ap54ia5clqvag38ctqbuqefasf.apps.googleusercontent.com

# Max price offers per conversation for a given listing (must align with backend policy).
CHAT_MAX_OFFERS_PER_CONVERSATION=3
# Create listing: true = at least one photo required on step 7 and at submit. false = can skip photos (Next enabled).
POST_REQUIRE_LISTING_IMAGES=true

# Public listing share / app-link base (no trailing slash). Use a host that serves HTML at /p/l/{id} (not raw API hosts).
# AndroidManifest VIEW filter: this host + pathPrefix /p/l/
LISTING_SHARE_BASE_URL=https://fashandcurious.com/p/l

# Marketing / legal pages (no trailing slash). App opens {base}/{vi|en}/terms and .../privacy. Override for local portal dev.
LEGAL_PORTAL_BASE_URL=https://fashandcurious.com

# Wallet return URL (HTTPS). Core must expose POST .../payments/initiate that proxies payment-service.
PAYMENT_REDIRECT_URL=https://fash.app/payment/callback
# Optional override: api/v1/orders/%s/payments/initiate
# CORE_PAYMENT_INITIATE_PATH=

# Realtime WebSocket service
REALTIME_BASE_URL=https://api-realtime.fashandcurious.com/

# C2C chat — fulfillment chooser: ship + online checkout (set false to show “đang phát triển” for that slice).
C2C_SHIP_FULFILLMENT_ENABLED=false
C2C_SHIP_ONLINE_PAYMENT_ENABLED=false

# Home “Đang giao” hub: true = list buying orders đang vận chuyển; false = màn hình “đang phát triển”.
SHIPPING=true

# Optional: HTTPS URL for meetup identity re-verification (Custom Tabs). Leave empty if KYC is only on web admin.
# IDENTITY_REVERIFY_URL=https://fash.app/account/verify-identity


# Guest browse — must match core-service PUBLIC_BROWSE_CLIENT_SECRETS (client id fash-android).
# URLs are https://api-core.../api/v1/public/... (no /vi/ prefix); locale via Accept-Language.
PUBLIC_BROWSE_CLIENT_ID=fash-android
PUBLIC_BROWSE_CLIENT_TOKEN=4bNy8z9TaA1qVb4rmUDqPFyKs6Gp7x3JXwZmFyAPQkY2RCesuKcTmN5Btb