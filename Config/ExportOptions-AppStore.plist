<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template for App Store export. CI replaces TEAM_ID_PLACEHOLDER at release time.
  See docs/CI.md and .github/workflows/ios-release.yml
-->
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store</string>
	<key>teamID</key>
	<string>TEAM_ID_PLACEHOLDER</string>
	<key>uploadSymbols</key>
	<true/>
	<key>signingStyle</key>
	<string>manual</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>BUNDLE_ID_PLACEHOLDER</key>
		<string>PROFILE_NAME_PLACEHOLDER</string>
	</dict>
	<key>stripSwiftSymbols</key>
	<true/>
</dict>
</plist>
